# OS noise
.DS_Store
Thumbs.db
*.swp
*~

# Editor noise
.vscode/
.idea/

# Secrets — keep these OUT of the repo
*.secret
*.key
*credentials*
# Note: real config files (running.txt, startup.txt) are committed.
# If a config contains plaintext secrets, scrub them before committing.

# Picocom / cu / minicom scratch files
*.capture
/tmp-*

# Anything inside a logs/ directory that we don't want to commit verbatim.
# Comment out if you want session logs versioned.
switches/*/logs/*
!switches/*/logs/.gitkeep
